# career-ops — Environment Variables (Makilesh's setup)
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ── Gemini (free tier, rotated by llm-router.mjs §7) ─────────────────────────
# Free API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the model IDs mapped to each rotation slot (limits stay
# attached to the slot). Only needed if Google's IDs differ from the defaults.
# GEMINI_MODEL_TRIAGE=gemini-3.1-flash-lite
# GEMINI_MODEL_EVAL=gemini-3.5-flash
# GEMINI_MODEL_EVAL_OVERFLOW=gemini-2.5-flash
# GEMINI_MODEL_PRO=gemini-3.1-pro-preview
# GEMINI_MODEL_PRO_OVERFLOW=gemini-2.5-pro

# Legacy single-model evaluator (gemini-eval.mjs) still honors this:
# GEMINI_MODEL=gemini-2.5-flash

# ── Local Qwen via Ollama (free, unlimited §7) ───────────────────────────────
# Install: https://ollama.com  →  ollama pull qwen2.5:14b  (q4_K_M for 12GB VRAM)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:14b
# OLLAMA_FALLBACK_MODEL=qwen2.5:7b
# OLLAMA_EMBED_MODEL=nomic-embed-text     # for qa-bank semantic matching (§6)

# ── Browser automation (headed/headless §8) ─────────────────────────────────
# CAREER_OPS_HEADED=1   # 1/true = visible browser (default). Overridden by CLI flags.
# CAREER_OPS_HEADLESS=1 # 1/true = headless (production runs)

# ── Other (optional) ─────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key_here
